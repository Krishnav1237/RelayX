{
  "name": "relayx",
  "version": "1.0.0",
  "description": "RelayX Backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npm run build && node dist/index.js",
    "dev:watch": "nodemon --watch src --ext ts --exec \"npm run build && node dist/index.js\"",
    "dev:full": "concurrently --names \"BACKEND,AXL\" --prefix-colors \"cyan,yellow\" \"npm:dev:watch\" \"npm:axl:sim\"",
    "axl:sim": "node scripts/axl-sim-node.cjs",
    "axl:node": "node scripts/axl-sim-node.cjs",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest --run",
    "test:transaction": "tsx test-real-transaction.ts",
    "test:comprehensive": "tsx comprehensive-test.ts",
    "debug": "tsx debug-backend.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Krishnav1237/RelayX.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/Krishnav1237/RelayX/issues"
  },
  "homepage": "https://github.com/Krishnav1237/RelayX#readme",
  "dependencies": {
    "@0gfoundation/0g-storage-ts-sdk": "^1.2.8",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "ethers": "^6.13.1",
    "express": "^5.2.1",
    "viem": "^2.48.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "axios": "^1.7.9"
  }
}
